        </mxCell>
        <mxCell id="d2" parent="1" style="rhombus;whiteSpace=wrap;fillColor=#005D7B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" value="TIME_WAIT 主要出现在哪一侧？" vertex="1">
