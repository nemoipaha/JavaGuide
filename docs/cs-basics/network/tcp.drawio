          <mxGeometry height="320" width="830" x="130" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="opt_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#2D3748;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;" value="&lt;b&gt;处理优先级（先应用侧，再系统参数）&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="300" x="150" y="1025" as="geometry" />
        </mxCell>
        <mxCell id="opt1" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#4CA497;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;shadow=1;" value="&lt;b&gt;1. 减少不必要的短连接&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;开启 HTTP keep-alive，复用连接池&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="370" x="160" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="opt2" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#0891B2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;shadow=1;" value="&lt;b&gt;2. 确认谁在主动关闭连接&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;服务端、客户端、网关、连接池都有可能&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="380" x="560" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="opt3" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;shadow=1;" value="&lt;b&gt;3. 检查应用侧资源释放&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;响应体、Socket、数据库连接、连接池归还&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="370" x="160" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="opt4" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#94A3B8;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;shadow=1;" value="&lt;b&gt;4. 扩大本地端口范围&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;确认同一目标端口耗尽后，再调 ip_local_port_range&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="380" x="560" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="opt5" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DC2626;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;shadow=1;" value="&lt;b&gt;5. 最后评估内核参数&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;tcp_tw_reuse 等需结合 Linux 版本、NAT、时间戳判断，不建议照抄&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="780" x="160" y="1210" as="geometry" />
        </mxCell>
        <mxCell id="tip" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#64748B;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontStyle=2;" value="&lt;b&gt;记住：TIME_WAIT 多不一定是故障，CLOSE_WAIT 多通常要先看代码。&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="700" x="200" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="es0" edge="1" parent="1" source="start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" target="d1">
